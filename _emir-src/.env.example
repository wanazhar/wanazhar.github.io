# Optional. The game runs with localStorage fallback if these are not provided.
# For Supabase persistence, create the SQL objects in supabase/schema.sql,
# then expose your public anon key here. Do not use service-role keys in the browser.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
